{
  "name": "cnbs-mcp-server",
  "version": "1.1.0",
  "description": "MCP server for China National Bureau of Statistics (CNBS) data access",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "cnbs-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "llms.txt",
    "README.md",
    "README.zh-CN.md",
    "License"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "tsup",
    "prebuild": "npm run typecheck",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js --port 12345",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "dev": "tsup --watch --onSuccess \"node dist/index.js --port 12345\""
  },
  "keywords": [
    "mcp",
    "statistics",
    "china",
    "nbs",
    "cnbs",
    "modelcontextprotocol",
    "gdp",
    "cpi",
    "population"
  ],
  "author": "Eliseo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Eliseowzy/cnbs-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/Eliseowzy/cnbs-mcp-server/issues"
  },
  "homepage": "https://github.com/Eliseowzy/cnbs-mcp-server#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.8.4",
    "commander": "^15.0.0",
    "lru-cache": "^11.5.2",
    "pino": "^10.1.0",
    "pino-roll": "^4.0.0",
    "prom-client": "^15.1.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0"
  }
}
